# REQUIRED
ASSISTANT_NAME=Codi
ENABLE_DESKTOP_ACTIONS=true
ENABLE_LOCAL_SHELL=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_IDS=123456789
# RBAC: subset of ALLOWED_USER_IDS. Admins get safety mode 'admin'; viewers get read-only commands.
# ADMIN_USER_IDS=123456789
# VIEWER_USER_IDS=
# Business users: read-only, query-only access to BUSINESS_ALLOWED_DIRS via /pilih-project
# BUSINESS_USER_IDS=
# BUSINESS_ALLOWED_DIRS=/home/hans/rotasi-staging
# Optional: explicit SQLite files for read-only business queries. If empty, Codi discovers *.db/*.sqlite/*.sqlite3 in the active business project.
# BUSINESS_DATABASE_PATHS=/home/hans/rotasi-staging/storage/app.sqlite
# Optional: PostgreSQL/MySQL read-only URLs. Use a database user with SELECT-only permissions.
# BUSINESS_DATABASE_URLS=postgresql://readonly:password@127.0.0.1:5432/app,mysql://readonly:password@127.0.0.1:3306/app

# AI Backend (codex atau claude)
AI_BACKEND=codex

# Codex
CODEX_BIN=codex
CODEX_TIMEOUT=600
CODEX_REASONING_EFFORT=medium
# Gunakan danger-full-access jika bwrap di server tidak support --argv0 (bwrap < 0.7)
CODEX_WRITE_SANDBOX_MODE=workspace-write
CODEX_WORK_DIR=/home/hans/AI-Agent-Telegram

# Claude
CLAUDE_BIN=claude
CLAUDE_MODEL=claude-sonnet-4-6
ALLOWED_WORK_DIRS=/home/hans/AI-Agent-Telegram

# Sessions
DEFAULT_ROLE=general
MAX_ACTIVE_SESSIONS=4
MAX_SESSIONS_PER_USER=3
SESSION_IDLE_TTL_MINUTES=60
MAX_QUEUE_PER_SESSION=1

# Output
MAX_OUTPUT_LENGTH=3000
LOCAL_SHELL_TIMEOUT=120

# Logging
LOG_LEVEL=INFO
LOG_FILE=

# Safety
MAX_REQUESTS_PER_MINUTE=5

# Repo watch
REPO_WATCH_POLL_SECONDS=30
MAX_WATCHED_REPOS_PER_USER=5

# Ops shortcuts
IMPORTANT_SERVICES=codex-agent.service

# Multi-device registry (fase 1)
ENABLE_DEVICE_REGISTRY=false
DEVICE_REGISTRY_PATH=/home/hans/AI-Agent-Telegram/codi-devices.json
DEVICE_API_HOST=127.0.0.1
DEVICE_API_PORT=8787
DEVICE_API_SHARED_TOKEN=replace_with_shared_secret
DEVICE_HEARTBEAT_TTL_SECONDS=90
